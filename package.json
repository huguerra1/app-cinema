{
  "name": "cinema_adm-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "start:backend": "npm run start:dev --workspace=backend",
    "start:frontend": "npm run dev --workspace=frontend",
    "dev": "concurrently \"npm:start:backend\" \"npm:start:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
